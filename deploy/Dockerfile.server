FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /beagrid-server ./cmd/server

FROM alpine:3.21
RUN apk --no-cache add ca-certificates
COPY --from=builder /beagrid-server /usr/local/bin/beagrid-server
EXPOSE 8080
ENTRYPOINT ["beagrid-server"]
